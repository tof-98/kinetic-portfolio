---
<section id="history" data-screen-label="History">
  <div class="wrap">
    <div class="shead rv">
      <span class="num">04</span>
      <span class="nm">History</span>
      <span class="rule"></span>
      <span class="meta">2016 → now</span>
    </div>
    <div class="gitlog rv">
      <div class="pbar">
        <span class="dot"></span>
        <span class="cmd">$ <b>git log</b> — career timeline · 2016 → now</span>
        <span class="live"><i></i>HEAD · main</span>
      </div>
      <div class="body">
        <div class="commit head">
          <div class="rail"><span class="node"></span></div>
          <div class="cm">
            <div class="cm-top">
              <span class="hash">a4f2e1c</span>
              <span class="ref headref"><span class="pt">HEAD →</span> main</span>
              <span class="when">2024 — NOW</span>
            </div>
            <h3>Full-Stack Developer<span class="caret"></span></h3>
            <div class="co">LITTERA Software &amp; Consulting · Hall in Tirol, AT</div>
            <ul class="msg">
              <li>Develop and optimise multi-layer web applications — performance, stability, maintainability.</li>
              <li>Design and implement RESTful APIs with authentication, documentation, and versioning.</li>
              <li>Shipped MFA (TOTP), SAML SSO with external partners, star-rating system, Scaleway email API, RFID migration, Solr autocomplete.</li>
              <li>Mentored and supported an intern through onboarding, feedback, and code reviews.</li>
            </ul>
          </div>
        </div>
        <div class="commit">
          <div class="rail"><span class="node"></span></div>
          <div class="cm">
            <div class="cm-top">
              <span class="hash">3e9a17f</span>
              <span class="ref"><span class="pt">tag:</span> collab</span>
              <span class="when">2023</span>
            </div>
            <h3>Software Developer</h3>
            <div class="co">Collaborative Project · Syria</div>
            <ul class="msg diff">
              <li>Implemented a full Gantt chart module using dhtmlxGantt (pure PHP, no framework), delivered within 6 months.</li>
            </ul>
          </div>
        </div>
        <div class="commit merge">
          <div class="rail"><span class="node"></span></div>
          <div class="cm">
            <div class="cm-top">
              <span class="hash">8c1d09b</span>
              <span class="ref"><span class="pt">tag:</span> edu</span>
              <span class="when">2016 — 2022</span>
            </div>
            <h3>B.Sc. Computer Science</h3>
            <div class="co">Tishreen University · Syria · EQF 6</div>
            <ul class="msg diff">
              <li>Software Engineering &amp; Information Systems.</li>
              <li>Focus on database design, network administration, and software development &amp; analysis.</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    const body = document.querySelector<HTMLElement>('#history .gitlog .body');
    if (!body) return;
    const nodes = [...body.querySelectorAll<HTMLElement>('.commit .node')];
    if (!nodes.length) return;

    const trail = document.createElement('span'); trail.className = 'tl-trail';
    const pulse = document.createElement('span'); pulse.className = 'tl-pulse';
    body.append(trail, pulse);

    const SEG_TRAVEL = 2150, PAUSE_MS = 300, HOLD_MS = 1100;

    type C = { el: HTMLElement; y: number; x: number };
    type Phase =
      | { type: 'pause';  node: C; y: number; dur: number }
      | { type: 'travel'; fromY: number; toY: number; dur: number }
      | { type: 'hold';   dur: number };

    let centers: C[] = [];
    let phases: Phase[] = [];
    let totalDur = 0;

    function measure() {
      const b = body!.getBoundingClientRect();
      centers = nodes.map(n => {
        const r = n.getBoundingClientRect();
        return { el: n, y: r.top - b.top + r.height / 2, x: r.left - b.left + r.width / 2 };
      });
      pulse.style.left = centers[0].x + 'px';
      trail.style.left = centers[0].x + 'px';

      const rev = [...centers].reverse(); // bottom node → top node
      const ps: Phase[] = [];
      for (let i = 0; i < rev.length; i++) {
        ps.push({ type: 'pause', node: rev[i], y: rev[i].y, dur: PAUSE_MS });
        if (i < rev.length - 1)
          ps.push({ type: 'travel', fromY: rev[i].y, toY: rev[i + 1].y, dur: SEG_TRAVEL });
      }
      ps.push({ type: 'hold', dur: HOLD_MS });
      phases = ps;
      totalDur = ps.reduce((s, p) => s + p.dur, 0);
    }

    const A = () => { const n = parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--A')); return n > 0 ? n : 1; };
    function reset() { nodes.forEach(n => n.classList.remove('lit')); }

    let raf: number | null = null, t0: number | null = null, prevE = Infinity;

    function loop(ts: number) {
      if (t0 == null) { t0 = ts; measure(); }
      const a = A();
      const scaled = totalDur / a;
      const e = (ts - t0) % scaled;
      if (e < prevE) reset();
      prevE = e;

      let acc = 0;
      for (const ph of phases) {
        const dur = ph.dur / a;
        if (e < acc + dur) {
          const p = (e - acc) / dur;
          if (ph.type === 'pause') {
            ph.node.el.classList.add('lit');
            pulse.style.top = ph.y + 'px'; trail.style.top = ph.y + 'px';
            pulse.style.opacity = '1'; trail.style.opacity = '0.85';
          } else if (ph.type === 'travel') {
            const pe = 0.5 - 0.5 * Math.cos(Math.PI * p);
            const y = ph.fromY + (ph.toY - ph.fromY) * pe;
            pulse.style.top = y + 'px'; trail.style.top = y + 'px';
            pulse.style.opacity = '1'; trail.style.opacity = '0.85';
          } else {
            centers.forEach(c => c.el.classList.add('lit'));
            const fade = p > 0.8 ? 1 - (p - 0.8) / 0.2 : 1;
            pulse.style.opacity = String(fade); trail.style.opacity = String(fade * 0.85);
          }
          break;
        }
        acc += dur;
      }

      raf = requestAnimationFrame(loop);
    }

    addEventListener('resize', () => { if (raf) measure(); }, { passive: true });
    const vio = new IntersectionObserver(es => es.forEach(e => {
      if (e.isIntersecting) { if (!raf) { t0 = null; prevE = Infinity; raf = requestAnimationFrame(loop); } }
      else if (raf) { cancelAnimationFrame(raf); raf = null; }
    }), { threshold: 0.12 });
    vio.observe(document.getElementById('history')!);
  })();
</script>
