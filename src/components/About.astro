<section id="about" data-screen-label="About">
  <div class="wrap">
    <div class="shead rv">
      <span class="num">01</span>
      <span class="nm">About — two modes</span>
      <span class="rule"></span>
      <span class="meta">the human / the engineer</span>
    </div>
    <div class="modes">

      <!-- THE HUMAN -->
      <div class="mode human rv">
        <div class="tag"><b>A</b>The human<span class="ln"></span>how I think</div>
        <h3>Clarity over<br />cleverness</h3>
        <p class="intro">I turn complex problems into clear, elegant systems. I care about the craft — not just shipping fast.</p>
        <div class="traits">
          <div class="trait">
            <span class="tn">DRIVE</span>
            <div>
              <div class="tt">What drives me</div>
              <div class="td">Turning messy problems into clean, secure systems that keep working long after I ship them.</div>
            </div>
          </div>
          <div class="trait">
            <span class="tn">METHOD</span>
            <div>
              <div class="tt">How I work</div>
              <div class="td">Calm, consistent, security-first. Solid beats clever-but-fragile, every time.</div>
            </div>
          </div>
          <div class="trait">
            <span class="tn">OFFLINE</span>
            <div>
              <div class="tt">Away from the keyboard</div>
              <div class="td">Training, cooking, and tinkering with self-hosted side projects — curiosity doesn't clock out.</div>
            </div>
          </div>
        </div>
        <div class="studio">
          <div class="st-head"><span class="st-kicker">A moment in my day</span></div>
          <div class="spot-stage" id="momentStage">
            <article class="spot-frame"><div class="kb"><img src="/gym.jpeg" alt="Training" width="800" height="600" loading="lazy" style="object-position: 9% top" /></div></article>
            <article class="spot-frame"><div class="kb"><img src="/church-left-side.jpeg" alt="Sacred Art" width="800" height="600" loading="lazy" style="object-position: 25% bottom;" /></div></article>
            <article class="spot-frame"><div class="kb"><img src="/me-looking-up.jpeg" alt="Lost in Art" width="800" height="600" loading="lazy" style="object-position: 5% bottom;" /></div></article>
            <article class="spot-frame"><div class="kb"><img src="/indisches-essen.jpeg" alt="Slow Dinner" width="800" height="600" loading="lazy" style="object-position: 25% bottom;" /></div></article>
            <div class="spot-cap"><span class="num" id="stIx">01<b> / 04</b></span><div class="ttl"><span id="stTtl">Training</span></div></div>
          </div>
          <div class="spot-strip" id="momentStrip"></div>
        </div>
      </div>

      <!-- THE ENGINEER -->
      <div class="mode eng rv" style="transition-delay:.08s">
        <div class="tag"><b>B</b>The engineer<span class="ln"></span>why I'm a fit</div>
        <h3>Production-tested,<br />ready now</h3>
        <p class="intro">
          <b>2+ years</b> shipping production features at <b>LITTERA Software &amp; Consulting</b> —
          live for real customers, used daily across Austria &amp; Germany.
        </p>
        <div class="bignums">
          <div class="bn"><div class="v" data-count="2" data-suffix="+">0</div><div class="k">years live</div></div>
          <div class="bn"><div class="v" data-count="12">0</div><div class="k">features</div></div>
          <div class="bn"><div class="v" data-count="3">0</div><div class="k">languages</div></div>
        </div>
        <div class="erow">
          <span class="k">Education</span>
          <span class="v">B.Sc. Computer Science<small>EQF 6 · Austria-recognised</small></span>
        </div>
        <div class="erow">
          <span class="k">Eligibility</span>
          <span class="v"><span class="ac">RWR – Karte plus</span><small>full labour-market access</small></span>
        </div>
        <div class="erow">
          <span class="k">Start</span>
          <span class="v">~3 months' notice<small>available from Sep 2026</small></span>
        </div>
        <div class="certled">
          <div class="cl-cap"><b>✦</b> Certifications<span class="ln"></span>verified · 04</div>
          <div class="clrow">
            <span class="cl-ghost" aria-hidden="true">AI</span>
            <span class="cl-tok">AI</span>
            <div class="cl-name">Google AI Professional Certificate</div>
            <span class="cl-org">Coursera · Jun 2026 <span class="vf">✓</span></span>
          </div>
          <div class="clrow">
            <span class="cl-ghost" aria-hidden="true">GOV</span>
            <span class="cl-tok">GOV</span>
            <div class="cl-name">AI Fundamentals &amp; Compliance</div>
            <span class="cl-org">Mindlane · Feb 2026 <span class="vf">✓</span></span>
          </div>
          <div class="clrow">
            <span class="cl-ghost" aria-hidden="true">SEC</span>
            <span class="cl-tok">SEC</span>
            <div class="cl-name">Google Cybersecurity</div>
            <span class="cl-org">Coursera · Dec 2025 <span class="vf">✓</span></span>
          </div>
          <div class="clrow">
            <span class="cl-ghost" aria-hidden="true">OOP</span>
            <span class="cl-tok">OOP</span>
            <div class="cl-name">OOP Java: Data Structures &amp; Beyond</div>
            <span class="cl-org">Coursera · Nov 2023 <span class="vf">✓</span></span>
          </div>
        </div>
        <div class="chips">
          <span class="chip">MFA · TOTP</span>
          <span class="chip">SAML SSO</span>
          <span class="chip">Solr search</span>
          <span class="chip">Versioned REST</span>
          <span class="chip">CI · Docker</span>
          <span class="chip-div"></span>
          <span class="chip lang"><b>AR</b> Native</span>
          <span class="chip lang"><b>DE</b> B2–C1</span>
          <span class="chip lang"><b>EN</b> B2</span>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  // Count-up animation
  const countUp = (el: HTMLElement) => {
    const t = +(el.dataset.count ?? 0);
    const suf = el.dataset.suffix ?? '';
    let s = 0;
    const step = Math.max(1, Math.round(t / 24));
    const id = setInterval(() => { s += step; if (s >= t) { s = t; clearInterval(id); } el.textContent = s + suf; }, 34);
  };
  const cio = new IntersectionObserver(
    es => es.forEach(e => { if (e.isIntersecting) { countUp(e.target as HTMLElement); cio.unobserve(e.target); } }),
    { threshold: 0.6 }
  );
  document.querySelectorAll('[data-count]').forEach(el => cio.observe(el));

  // About — "a moment in my day" Spotlight + Filmstrip
  (function () {
    const stage = document.getElementById('momentStage') as HTMLElement;
    if (!stage) return;
    const frames = [...stage.querySelectorAll<HTMLElement>('.spot-frame')];
    const N = frames.length;
    const stripEl = document.getElementById('momentStrip') as HTMLElement;
    const idxEl = document.getElementById('stIx');
    const ttlEl = document.getElementById('stTtl');
    const capEl = stage.querySelector<HTMLElement>('.spot-cap');
    const DUR = 4400;
    const MOMENTS = [
      { t: 'Training',        src: '/gym.jpeg' },
      { t: 'Sacred Art',      src: '/church-left-side.jpeg' },
      { t: 'Lost in Art',     src: '/me-looking-up.jpeg' },
      { t: 'SLOW DINNER', src: '/indisches-essen.jpeg' }
    ];
    let idx = 0, paused = false, elapsed = 0, lastT = performance.now();
    try { const s = +(localStorage.getItem('kinetic-moment-idx') ?? ''); if (!isNaN(s) && s >= 0 && s < N) idx = s; } catch {}
    const strip = MOMENTS.map((mo, i) => {
      const b = document.createElement('button') as HTMLButtonElement;
      b.className = 'fs'; b.type = 'button'; b.title = mo.t; b.setAttribute('aria-label', mo.t);
      b.innerHTML = '<img src="' + mo.src + '" alt="' + mo.t + '" /><span class="fs-prog"></span>';
      b.addEventListener('click', () => jump(i));
      stripEl.appendChild(b);
      return b;
    });
    frames.forEach((f, i) => { f.style.cursor = 'pointer'; f.addEventListener('click', () => jump(i)); });
    function jump(i: number) { idx = ((i % N) + N) % N; elapsed = 0; strip.forEach(b => (b.querySelector('.fs-prog') as HTMLElement).style.width = '0%'); paint(); }
    function paint() {
      frames.forEach((f, i) => {
        let rel = i - idx; if (rel > N / 2) rel -= N; if (rel < -N / 2) rel += N;
        const a = Math.abs(rel), sgn = Math.sign(rel);
        let x: number, z: number, ry: number, sc: number, op: number, fl: string, zi: number;
        if (a === 0) { x = 0; z = 0; ry = 0; sc = 1; op = 1; fl = 'none'; zi = 4; }
        else if (a === 1) { x = sgn * 42; z = -205; ry = -sgn * 26; sc = .86; op = .58; fl = 'grayscale(.8) brightness(.55)'; zi = 3; }
        else { x = sgn * 58; z = -360; ry = -sgn * 30; sc = .74; op = .14; fl = 'grayscale(1) brightness(.35)'; zi = 2; }
        f.style.transform = `translate(-50%,-50%) translateX(${x}%) translateZ(${z}px) rotateY(${ry}deg) scale(${sc})`;
        f.style.opacity = String(op); f.style.filter = fl; f.style.zIndex = String(zi);
        f.style.pointerEvents = a > 1 ? 'none' : 'auto';
        f.classList.toggle('on', a === 0);
      });
      strip.forEach((b, i) => b.classList.toggle('on', i === idx));
      if (idxEl) idxEl.innerHTML = '0' + (idx + 1) + '<b> / 0' + N + '</b>';
      if (capEl) { capEl.classList.remove('lit'); void capEl.offsetWidth; requestAnimationFrame(() => capEl!.classList.add('lit')); }
      if (ttlEl) ttlEl.textContent = MOMENTS[idx].t;
      try { localStorage.setItem('kinetic-moment-idx', String(idx)); } catch {}
    }
    function tick(now: number) {
      const dt = now - lastT; lastT = now;
      if (!paused) {
        elapsed += dt;
        const fr = Math.min(elapsed / DUR, 1);
        const fs = strip[idx]; if (fs) (fs.querySelector('.fs-prog') as HTMLElement).style.width = (fr * 100) + '%';
        if (elapsed >= DUR) { elapsed = 0; strip.forEach(b => (b.querySelector('.fs-prog') as HTMLElement).style.width = '0%'); idx = (idx + 1) % N; paint(); }
      }
      requestAnimationFrame(tick);
    }
    let hov = false;
    stage.addEventListener('mouseenter', () => { paused = true; hov = true; });
    stage.addEventListener('mouseleave', () => { paused = false; hov = false; });
    addEventListener('keydown', e => { if (!hov) return; if (e.key === 'ArrowLeft') jump(idx - 1); else if (e.key === 'ArrowRight') jump(idx + 1); });
    paint();
    requestAnimationFrame(tick);
  })();
</script>
